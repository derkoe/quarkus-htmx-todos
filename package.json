{
  "devDependencies": {
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-java": "2.10.2",
    "simple-git-hooks": "2.13.1"
  },
  "lint-staged": {
    "**/*.{json,yml,yaml,java}": [
      "prettier --write",
      "git add"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
